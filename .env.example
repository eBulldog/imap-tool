# Copy to .env (not committed) or export in your shell.

IMAP_HOST=mail.example.com
IMAP_PORT=993
# true = TLS immediately (typical). false = cleartext or STARTTLS per server.
IMAP_SECURE=true
IMAP_USER=user@example.com
IMAP_PASS=

# Optional: set to 0 only for lab/self-signed (insecure).
# IMAP_TLS_REJECT_UNAUTHORIZED=1

# Web UI (imap-tool ui): default bind is all IPv4 interfaces (LAN). Restrict with:
# IMAP_UI_HOST=127.0.0.1
# IMAP_UI_PORT=3847

# UI verified-copy jobs (spec.json + job.sqlite per UUID). Default: under system temp.
# IMAP_COPY_JOB_DIR=/var/lib/imap-tool/copy-jobs
